{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Item": {
      "title": "Item",
      "description": "A found item report",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "imageUrl": { "type": "string" },
        "foundAt": { "type": "string", "format": "date-time" },
        "finderId": { "type": "string" },
        "finderName": { "type": "string" },
        "finderEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["found", "claimed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "location", "finderId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Found item reports"
    }
  }
}
