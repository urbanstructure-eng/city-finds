rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - photoURL: string
    //   - createdAt: timestamp
    //   - city: string
    //   - country: string
    //   - language: string
    //
    // Collection: items
    // Document ID: {itemId}
    // Fields:
    //   - title: string (required)
    //   - description: string
    //   - location: string (required)
    //   - imageUrl: string
    //   - foundAt: timestamp
    //   - finderId: string (required)
    //   - finderName: string
    //   - finderEmail: string
    //   - status: string (required, 'found' | 'claimed')
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.finderId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 255 &&
             (!('city' in data) || (data.city is string && data.city.size() < 100)) &&
             (!('country' in data) || (data.country is string && data.country.size() < 100)) &&
             (!('language' in data) || (data.language is string && data.language.size() < 50)) &&
             (!('voiceEnabled' in data) || (data.voiceEnabled is bool)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "urbanstructure@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidItem(data) {
      let requiredFields = ['title', 'location', 'finderId', 'status', 'type'];
      return data.keys().hasAll(requiredFields) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
             data.status in ['found', 'claimed', 'lost'] &&
             data.type in ['found', 'lost'] &&
             (!('reward' in data) || (data.reward is string && data.reward.size() < 100));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /items/{itemId} {
      allow read: if true; // Publicly searchable
      allow create: if (isAuthenticated() && isValidItem(request.resource.data) && (request.resource.data.finderId == request.auth.uid || isAdmin())) || isAdmin();
      allow update: if (isAdmin() || 
                       (isDocOwner() && request.resource.data.status != 'claimed') || 
                       (isAuthenticated() && resource.data.status == 'found' && request.resource.data.status == 'claimed' && request.auth.uid != resource.data.finderId)) && 
                       isValidItem(request.resource.data) && 
                       (request.resource.data.finderId == resource.data.finderId);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
